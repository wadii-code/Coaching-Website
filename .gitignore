# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local dev / tooling artifacts
/.dev-server.log
/.playwright-mcp/
# stray screenshots at repo root (real assets live in /public)
/*.png

# machine-local Claude Code settings (keep launch.json shared)
.claude/settings.local.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
