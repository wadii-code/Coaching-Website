# ─────────────────────────────────────────────────────────────
# 3OCTBR — environment variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Supabase (project URL + keys from the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-side ONLY. Never expose to the client / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Public site URL (used for metadata, OG, auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email notifications (Resend) — optional until forms go live
RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=

# Rate limiting (Upstash Redis REST) — optional until forms go live
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
